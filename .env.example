# Discord Bot Token (from https://discord.com/developers/applications)
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Bot Owner Discord ID (optional — for admin commands)
BOT_OWNER_ID=

# Admin Panel Discord ID (for web admin dashboard access, defaults to BOT_OWNER_ID)
ADMIN_DISCORD_ID=

# Bot Admin Channel ID (optional — private channel for bot alerts)
ADMIN_CHANNEL_ID=

# Gmail SMTP Settings (for email escalation reminders)
GMAIL_ADDRESS=your_email@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password_here

# Default Timezone (used for new user registrations)
TIMEZONE=Asia/Kolkata

# Gemini API Key (optional — for AI analysis)
GEMINI_API_KEY=

# Database Connection
DATABASE_URL=postgresql://user:password@localhost:5432/dsa_bot

# ── FastAPI REST API ──────────────────────────
# Host and port for the API server
API_HOST=0.0.0.0
API_PORT=8000

# ── Discord OAuth2 (Dashboard Login) ─────────
# Create an OAuth2 application at https://discord.com/developers/applications
# Add redirect URI: http://localhost:8000/auth/callback (or your production URL)
DISCORD_CLIENT_ID=your_discord_oauth_client_id
DISCORD_CLIENT_SECRET=your_discord_oauth_client_secret
DISCORD_OAUTH_REDIRECT_URI=http://localhost:8000/auth/callback
# Mobile OAuth redirect (server endpoint that exchanges code then issues dsabot:// deep link)
# Production: https://dsabot.in/api/auth/mobile-callback
# Must also be registered in Discord Developer Portal → OAuth2 → Redirects
DISCORD_OAUTH_MOBILE_REDIRECT_URI=http://localhost:8000/auth/mobile-callback

# ── Session / JWT ────────────────────────────
# Generate a random secret: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=change-me-to-a-random-secret-key
COOKIE_SECURE=false

# ── Frontend URL ─────────────────────────────
# URL where the React frontend is served (for OAuth redirects)
FRONTEND_URL=http://localhost:3000
